# Copy to .env for local development (do not commit .env)
# Do NOT paste VAR=value lines into PowerShell — edit this file, or use: $env:VAR = "value"

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (optional locally — uses SQLite if unset)
# DATABASE_URL=postgresql://user:pass@localhost:5432/office_suite_v2

# Task module (off on production until UAT sign-off)
ENABLE_TASK_MODULE=0

# Client documents — set ENABLE_DOCUMENTS_MODULE=1 locally to test; keep 0 on live until go-live
ENABLE_DOCUMENTS_MODULE=1
# local = files under media/ on your machine; spaces = DigitalOcean Spaces (production)
DOCUMENT_STORAGE=local
# DOCUMENT_MAX_UPLOAD_BYTES=26214400
# When DOCUMENT_STORAGE=spaces (live only):
# DO_SPACES_KEY=your-spaces-access-key-id
# DO_SPACES_SECRET=your-spaces-secret-shown-once-at-create
# DO_SPACES_BUCKET=ca-office-documents-prod
# DO_SPACES_REGION=blr1
# DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
# Endpoint must match bucket region (no bucket name in URL).
# Access key needs Read/Write/Delete on that bucket.
# After deploy, run: python manage.py check_document_storage